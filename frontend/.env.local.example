# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; .env.local.example is committed as a template.
#
# After editing, RESTART the dev server (Ctrl+C, then `npm run dev`).
# Next.js only reads env vars at startup.

# ── REST API base URL ──────────────────────────────────────────────────
# Used for: login, logout, patients, diagnose (all standard HTTP endpoints).
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/<stage>
NEXT_PUBLIC_API_URL=https://YOUR-API-ID.execute-api.us-east-1.amazonaws.com/prod

# ── WebSocket API URL ──────────────────────────────────────────────────
# Reserved for future use: real-time push of diagnostic results from the
# inference worker (FR-6.2). Not used by current frontend code.
# Format: wss://<api-id>.execute-api.<region>.amazonaws.com/<stage>
NEXT_PUBLIC_WS_URL=wss://YOUR-WS-API-ID.execute-api.us-east-1.amazonaws.com/prod
